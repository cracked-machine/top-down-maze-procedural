{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Inventory Items",
  "type": "object",
  "patternProperties": {
    "^(item\\..+|ERROR_SPRITE)$": {
      "type": "object",
      "required": ["sprite", "actions"],
      "additionalProperties": false,
      "properties": {
        "sprite": {
          "type": "string",
          "description": "The sprite identifier for the item"
        },
        "actions": {
          "type": "array",
          "description": "List of actions available for this item",
          "minItems": 6,
          "maxItems": 6,
          "allOf": [
            { "contains": { "required": ["bury_action"] } },
            { "contains": { "required": ["carry_action"] } },
            { "contains": { "required": ["consume_action"] } },
            { "contains": { "required": ["destroy_action"] } },
            { "contains": { "required": ["exhume_action"] } },
            { "contains": { "required": ["sacrifice_action"] } }
          ],
          "items": {
            "type": "object",
            "maxProperties": 1,
            "patternProperties": {
              "^(bury|carry|consume|destroy|exhume|sacrifice)_action$": {
                "type": "object",
                "required": ["health", "fear", "despair", "infamy", "disease", "tick"],
                "additionalProperties": false,
                "properties": {
                  "health":  { "type": "number" },
                  "fear":    { "type": "number" },
                  "despair": { "type": "number" },
                  "infamy":  { "type": "number" },
                  "disease": {
                    "type": "object",
                    "required": ["type", "tick"],
                    "additionalProperties": false,
                    "properties": {
                      "type": {
                        "type": "string",
                        "enum": ["none", "rabies", "plague", "leprosy"]
                      },
                      "tick": { "type": "number" }
                    }
                  },
                  "tick": { 
                    "type": "number"
                  }
                }
              }
            },
            "additionalProperties": false
          }
        }
      }
    }
  },
  "additionalProperties": false
}